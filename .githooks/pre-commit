#!/bin/sh
set -eu

blocked_paths=$(
  git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r path; do
    if [ "$path" = "data/README.md" ] || [ "$path" = "data/.gitignore" ]; then
      continue
    fi

    if [ "${path#data/}" != "$path" ]; then
      printf '%s\n' "$path"
    fi
  done
)

if [ -n "$blocked_paths" ]; then
  printf '%s\n' "Blocked: raw data under data/ must not be committed."
  printf '%s\n' "$blocked_paths"
  exit 1
fi
